# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASS=admin123
RABBITMQ_MANAGEMENT_PORT=15672

# POS Service
POS_PORT=3001
POS_DB=/app/data/pos.db

# Inventory Service
INVENTORY_PORT=3002
INVENTORY_DB=/app/data/inventory.db

# Accounting Service
ACCOUNTING_PORT=3003
ACCOUNTING_DB=/app/data/accounting.db

# E-Commerce Service
ECOMMERCE_PORT=3004
ECOMMERCE_DB=/app/data/ecommerce.db

# CRM Service
CRM_PORT=3005
CRM_DB=/app/data/crm.db

# API Gateway
GATEWAY_PORT=3000

# Transformer
TRANSFORMER_PORT=3006

# Queue Names
QUEUE_SALE_CREATED=sale.created
QUEUE_STOCK_UPDATED=stock.updated
QUEUE_ACCOUNTING_ENTRY=accounting.entry
QUEUE_CRM_UPDATE=crm.update
QUEUE_ECOMMERCE_SYNC=ecommerce.sync